rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function roomPath(roomCode) {
      return /databases/$(database)/documents/rooms/$(roomCode);
    }

    function roomDoc(roomCode) {
      return get(roomPath(roomCode));
    }

    function isRoomOwner(roomCode) {
      return isSignedIn() && exists(roomPath(roomCode)) && roomDoc(roomCode).data.ownerUid == request.auth.uid;
    }

    function isDeletingOwnRoom(roomCode) {
      return isSignedIn() &&
        exists(roomPath(roomCode)) &&
        !existsAfter(roomPath(roomCode)) &&
        roomDoc(roomCode).data.ownerUid == request.auth.uid;
    }

    function isRoomMember(roomCode) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/rooms/$(roomCode)/liveLocations/$(request.auth.uid));
    }

    match /rooms/{roomCode} {
      // Join flow reads the room by code before creating member doc.
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.roomName is string &&
        request.resource.data.isActive == true;

      allow update, delete: if isRoomOwner(roomCode);

      match /liveLocations/{uid} {
        allow read: if isSignedIn();

        allow create, update: if isSignedIn() && uid == request.auth.uid;

        // Owner can clean up any member doc when ending room. Users can delete themselves on leave.
        allow delete: if isSignedIn() && (
          uid == request.auth.uid ||
          isRoomOwner(roomCode) ||
          isDeletingOwnRoom(roomCode)
        );
      }

      match /messages/{messageId} {
        allow read: if isSignedIn() && (isRoomMember(roomCode) || isRoomOwner(roomCode));

        allow create: if isSignedIn() &&
          (isRoomMember(roomCode) || isRoomOwner(roomCode)) &&
          request.resource.data.senderUid == request.auth.uid &&
          request.resource.data.senderName is string &&
          request.resource.data.type in ['text', 'place'];

        allow update: if false;
        allow delete: if isSignedIn() && (isRoomOwner(roomCode) || isDeletingOwnRoom(roomCode));
      }
    }
  }
}
